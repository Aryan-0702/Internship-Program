@model List<StudentCrudApp.Models.Student>

<h2>Student List</h2>

<a href="/Student/Create">Add New Student</a>

<table border="1" cellpadding="10">
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Dept</th>
        <th>Year</th>
        <th>Marks</th>
        <th>Actions</th>
    </tr>

@foreach(var s in Model)
{
<tr>
<td>@s.Id</td>
<td>@s.Name</td>
<td>@s.Department</td>
<td>@s.Year</td>
<td>@s.Marks</td>
<td>
<a href="/Student/Details/@s.Id">View</a> |
<a href="/Student/Edit/@s.Id">Edit</a> |
<a href="/Student/Delete/@s.Id">Delete</a>
</td>
</tr>
}
</table>