@model List<StudentDbApp.Models.Student>

<h2>Student List</h2>

<a href="/Student/Create">Add Student</a>

<table border="1" cellpadding="10">
<tr>
<th>Id</th>
<th>Name</th>
<th>Dept</th>
<th>Year</th>
<th>Marks</th>
</tr>

@foreach(var s in Model)
{
<tr>
<td>@s.Id</td>
<td>@s.Name</td>
<td>@s.Department</td>
<td>@s.Year</td>
<td>@s.Marks</td>
</tr>
}
</table>